# Morpheus environment variables
# Copy this file to `.env.local` and fill in your secrets.
# .env.local is gitignored — never commit it.

# ─── Anthropic API key ─────────────────────────────────────────────
# Required to enable the in-canvas Strategy Assistant chat panel.
# Get one from https://console.anthropic.com/ → Settings → API Keys
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# ─── Optional: override the model used by the chat panel ───────────
# Default is claude-haiku-4-5-20251001 (cheap + fast). For higher
# quality answers (slower, ~10x cost) try claude-sonnet-4-5-20250929
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
